// ===================== STRUCTURES DE BASE =====================

// Vecteur 3D standard utilisé pour toute la géométrie du problème
// (position DOM, position muon, directions, reconstruction)
struct Vec3 {
    double x, y, z;

    Vec3 operator-(const Vec3& v) const { return {x - v.x, y - v.y, z - v.z}; }
    Vec3 operator+(const Vec3& v) const { return {x + v.x, y + v.y, z + v.z}; }
    Vec3 operator*(double s) const { return {x * s, y * s, z * s}; }
    double dot(const Vec3& v) const { return x * v.x + y * v.y + z * v.z; }
    double norm() const { return std::sqrt(x * x + y * y + z * z); }
    Vec3 normalized() const { 
        double n = norm(); 
        return (n > 0) ? Vec3{x / n, y / n, z / n} : Vec3{0, 0, 0}; 
    }
};

struct Hit {
    Vec3 pos;
    double time;
};

// ===================== CONSTANTES ARCA =====================

const int N_DU = 115;          
const int N_DOMS = 18;         
const double Z_SPACING = 36.0; 
const double H_DET = 612.0;    

const double REF_INDEX = 1.33;
const double C_LIGHT = 0.299792458;
const double COS_THETA_C = 1.0 / REF_INDEX;

const double MAX_PHOTON_RADIUS = 120.0;
const double PHOTON_STEP = 0.5;

const double R_CYL_GEN = 650.0;
const double H_CYL_GEN = H_DET + 200.0;

// ===================== GÉOMÉTRIE =====================

