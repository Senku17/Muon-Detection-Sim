// ===================== ANALYSE PÉRIODICITÉ =====================

bool check_periodicity(const std::vector<Hit>& hits, const Vec3& dir_reco) {
    if (hits.size() < 4) return false;

    std::vector<double> proj;
    for (const auto& h : hits) proj.push_back(h.pos.dot(dir_reco));

    std::sort(proj.begin(), proj.end());

    std::vector<double> diffs;
    for (size_t i = 1; i < proj.size(); ++i) {
        double d = proj[i] - proj[i-1];
        if (d > 2.0) diffs.push_back(d);
    }

    if (diffs.empty()) return false;

    double mean = std::accumulate(diffs.begin(), diffs.end(), 0.0) / diffs.size();
    double var = 0;
    for (double d : diffs) var += (d - mean) * (d - mean);

    return (std::sqrt(var / diffs.size()) / mean < 0.28);
}

// ===================== SIMULATION =====================

void simulate_event(const Vec3& mu_start, const Vec3& mu_dir,
                    const std::vector<Vec3>& detector,
                    std::vector<Hit>& hits) {

    hits.clear();
    std::set<int> hit_indices;

    const double L_ATT = 60.0;
    const double CHERENKOV_SIGMA = 0.07;

    for (double t = 0; t < 2000; t += PHOTON_STEP) {

        Vec3 mu_pos = mu_start + mu_dir * t;

        for (size_t i = 0; i < detector.size(); ++i) {

            if (hit_indices.count(i)) continue;

            Vec3 to_dom = detector[i] - mu_pos;
            double dist = to_dom.norm();

            if (dist > MAX_PHOTON_RADIUS) continue;

            Vec3 u_to_dom = to_dom.normalized();

            double cos_angle = mu_dir.dot(u_to_dom);
            double angle = acos(cos_angle);
            double theta_c = acos(COS_THETA_C);

            double cone_weight =
                exp(-pow(angle - theta_c, 2) /
                    (2 * CHERENKOV_SIGMA * CHERENKOV_SIGMA));

            if (cone_weight < 0.5) continue;

            double attenuation = exp(-dist / L_ATT);
            double r = (double)rand() / RAND_MAX;

            if (r < attenuation) {

                double mu_speed = C_LIGHT * 0.999;
                double muon_time = t / mu_speed;

                double photon_time = dist / (C_LIGHT / REF_INDEX);

                double emission_jitter =
                    ((double)rand() / RAND_MAX - 0.5) * 1.5;

                hits.push_back({detector[i],
                                muon_time + photon_time + emission_jitter});

                hit_indices.insert(i);
            }
        }
    }
}

// ===================== MAIN =====================

int main() {

    std::srand(std::time(NULL));

    std::vector<Vec3> detector;
    build_detector(detector);

    int n_target;

    std::cout << "--- SIMULATION & RECONSTRUCTION ARCA ---\nNombre de muons a simuler : ";

    if (!(std::cin >> n_target)) return 1;

    double total_error = 0;
    long long total_hits = 0;
    int periodic_count = 0;
    int count = 0;

    std::ofstream out("data.txt");            // fichier général
    std::ofstream out_periodic("periodic.txt"); // fichier périodicité uniquement

    while (count < n_target) {

        Vec3 m_pos, m_dir;

        double phi = (rand() / (double)RAND_MAX) * 2.0 * M_PI;
        double costh = 2.0 * (rand() / (double)RAND_MAX) - 1.0;
        double sinth = std::sqrt(1.0 - costh * costh);

        m_dir = {sinth * cos(phi), sinth * sin(phi), costh};

        double phi_gen = (rand() / (double)RAND_MAX) * 2.0 * M_PI;
        m_pos = {R_CYL_GEN * cos(phi_gen),
                 R_CYL_GEN * sin(phi_gen),
                 (rand() / (double)RAND_MAX) * H_CYL_GEN - H_CYL_GEN/2.0};

        Vec3 true_dir = m_dir.normalized();

        std::vector<Hit> hits;
        simulate_event(m_pos, true_dir, detector, hits);

        if (hits.size() >= 5) {

            std::sort(hits.begin(), hits.end(),
                      [](const Hit& a, const Hit& b){ return a.time < b.time; });

            Vec3 reco_dir = (hits.back().pos - hits.front().pos).normalized();

            double err =
                std::acos(std::min(1.0, std::max(-1.0,
                true_dir.dot(reco_dir)))) * (180.0 / M_PI);

            bool periodic = check_periodicity(hits, reco_dir);

            total_error += err;
            total_hits += hits.size();
            if (periodic) periodic_count++;
            count++;

            // fichier général
            out << hits.size() << " " << err << "\n";

            // fichier périodicité uniquement
            if (periodic) {
                out_periodic << hits.size() << " " << err << "\n";
            }

            // affichage console
            std::cout << std::fixed << std::setprecision(3);
            std::cout << "--------------------------------------------------\n";
            std::cout << "MUON #" << count << " | " << hits.size() << " DOMs touches" << std::endl;
            std::cout << "DIRECTION REELLE : (" << true_dir.x << ", " << true_dir.y << ", " << true_dir.z << ")" << std::endl;
            std::cout << "DIRECTION RECO   : (" << reco_dir.x << ", " << reco_dir.y << ", " << reco_dir.z << ")" << std::endl;
            std::cout << "ERREUR ANGULAIRE : " << err << " degres" << std::endl;
            std::cout << "PERIODICITE      : " << (periodic ? "DETECTEE" : "NON-DETECTEE") << std::endl;
        }
    }

    std::cout << "\n\n==================================================\n";
    std::cout << "          BILAN STATISTIQUE SUR " << n_target << " MUONS\n";
    std::cout << "==================================================\n";
    std::cout << std::fixed << std::setprecision(2);
    std::cout << "Moyenne de DOMs touches par muon : " << (double)total_hits / n_target << std::endl;
    std::cout << "Erreur angulaire moyenne         : " << total_error / n_target << " degres" << std::endl;
    std::cout << "Taux de detection de periodicite : " << (double)periodic_count / n_target * 100.0 << " %" << std::endl;
    std::cout << "==================================================\n";

    out.close();
    out_periodic.close();

    return 0;
}
